# Supabase credentials — copy this file to `.env` for local builds, and set the
# same two variables in the Vercel dashboard (Settings → Environment Variables).
#
# Find these in your Supabase project: Settings → API
#   • Project URL  -> SUPABASE_URL
#   • Project API keys -> "anon" / "public" key -> SUPABASE_ANON_KEY
#
# The anon key is safe to expose in the browser — Row Level Security on the
# `content_plan` table is what protects the data.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
